{
  "name": "upeva",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "bash deploy.sh",
    "test:rules": "XDG_CONFIG_HOME=.firebase/config FIREBASE_CLI_DISABLE_UPDATE_CHECK=true NO_UPDATE_NOTIFIER=1 firebase emulators:exec --project demo-upeva-test --only firestore,storage \"vitest run tests/rules\"",
    "test:emulators": "npm run test:rules",
    "seed:archive-test": "node functions/scripts/seed-archive-test.cjs",
    "run:archive-test": "node functions/scripts/run-archive-cleanup-test.cjs",
    "verify:archive-test": "node functions/scripts/verify-archive-test.cjs",
    "clean:archive-test": "node functions/scripts/clean-archive-test.cjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.2",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-is": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.16.0",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.1.5",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  }
}
# Local emulator secrets — copy this file to .secret.local and keep it LOCAL ONLY.
# .secret.local is gitignored. Never commit real keys. Never use these values in production.
# Production secrets live exclusively in Firebase Secret Manager.
#
# PII_ENCRYPTION_KEY must be exactly 64 hex characters (32 bytes for AES-256-GCM).
# HMAC_SECRET_KEY can be any string.
#
# These example values are intentionally public and ONLY safe for the local emulator.

PII_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
HMAC_SECRET_KEY=upeva-local-dev-only-not-for-production

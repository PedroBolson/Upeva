rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Animal photos: public read, authenticated staff write.
    // Since only staff have Firebase Auth accounts, auth != null is sufficient.
    match /animals/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024  // 10 MB max
        && request.resource.contentType.matches('image/.*');
    }
  }
}

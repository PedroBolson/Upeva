rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isStaff() {
      return request.auth != null
        && request.auth.token.role in ['admin', 'reviewer'];
    }

    // Animal photos: public read, staff write only.
    // Uses Custom Claims (request.auth.token.role) set by Cloud Functions,
    // so no Firestore reads are needed inside Storage rules.
    match /animals/{allPaths=**} {
      allow read: if true;
      allow create, update: if isStaff()
        && request.resource.size < 5 * 1024 * 1024  // 5 MB max
        && request.resource.contentType in [
          'image/jpeg',
          'image/jpg',
          'image/png',
          'image/webp'
        ];
      allow delete: if isStaff();
    }

    // Private PDF archive: no direct client access under any circumstances.
    // Cloud Functions (Admin SDK) write here; signed URLs are issued server-side
    // only, after role validation, by the getArchiveFileUrl callable.
    match /private-pdfs/{allPaths=**} {
      allow read, write: if false;
    }
  }
}

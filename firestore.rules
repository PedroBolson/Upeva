rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Catch-all deny (Melhoria 9) ────────────────────────────────────────────
    // All collections not explicitly listed below are denied by default.
    // This rule is evaluated last (more specific rules take precedence).
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    // Uses Custom Claims (request.auth.token.role) set by Cloud Functions.
    // This eliminates Firestore reads inside security rules, reducing costs
    // and latency on every request.

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isReviewer() {
      return hasRole('reviewer');
    }

    function isStaff() {
      return isAdmin() || isReviewer();
    }

    function isArchivedTransition() {
      return resource.data.status != 'archived'
        && request.resource.data.status == 'archived';
    }

    function isPublicSafeAnimal() {
      return resource.data.status in ['available', 'under_review'];
    }

    function hasInternalAnimalTraceability() {
      return resource.data.keys().hasAny([
        'createdBy', 'updatedBy', 'updatedByLabel',
        'archiveReason', 'archiveDetails', 'archiveDate', 'archivedBy', 'archivedByLabel'
      ]);
    }

    function hasTraceabilityWrite(keys) {
      return keys.hasAny([
        'createdBy', 'updatedBy', 'updatedByLabel',
        'reviewedBy', 'reviewedByLabel', 'reviewedAt', 'reviewAction',
        'archiveReason', 'archiveDetails', 'archiveDate', 'archivedBy', 'archivedByLabel', 'archivedAt',
        'roleUpdatedBy', 'roleUpdatedByLabel', 'roleUpdatedAt'
      ]);
    }

    function hasAnimalStatusWrite(keys) {
      return keys.hasAny(['status']);
    }

    // ── Animals ────────────────────────────────────────────────────────────────
    // Public read only for public-safe statuses; staff can read all and
    // create/edit/delete.
    // Create validates required fields and enum values (Melhoria 5).

    match /animals/{animalId} {
      allow read: if isStaff() || (isPublicSafeAnimal() && !hasInternalAnimalTraceability());

      allow create: if isStaff()
        && request.resource.data.keys().hasAll(['name', 'species', 'status', 'sex', 'description'])
        && !hasTraceabilityWrite(request.resource.data.keys())
        && request.resource.data.status in ['available', 'under_review']
        && request.resource.data.species in ['dog', 'cat'];

      allow update: if isStaff()
        && !isArchivedTransition()
        && !hasTraceabilityWrite(request.resource.data.diff(resource.data).affectedKeys())
        && !hasAnimalStatusWrite(request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isStaff();
    }

    // ── Adoption applications ──────────────────────────────────────────────────
    // All creates go through the createApplication Cloud Function (Admin SDK
    // bypasses rules). Direct client writes are blocked to enforce rate limiting
    // and server-side validation.
    // Update validates status enum values to prevent invalid states (Melhoria 2).

    match /applications/{appId} {
      allow create: if false; // Cloud Function only

      allow read, delete: if isStaff();

      allow update: if false; // Cloud Function only
    }

    // ── User profiles ──────────────────────────────────────────────────────────
    // All writes go through Cloud Functions (Admin SDK bypasses rules).
    // Any authenticated staff member can read their own profile. Only admins
    // can read or list other users. Users may only edit their own display name.

    match /users/{userId} {
      allow get: if isAuthenticated() &&
        (request.auth.uid == userId || isAdmin());

      allow list: if isAdmin();

      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'uid', 'email', 'displayName', 'role', 'createdAt', 'createdBy'
        ])
        && request.resource.data.keys().hasOnly([
          'uid', 'email', 'displayName', 'role', 'createdAt', 'createdBy',
          'updatedAt', 'updatedBy', 'updatedByLabel',
          'roleUpdatedAt', 'roleUpdatedBy', 'roleUpdatedByLabel'
        ])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['displayName', 'updatedAt']);

      allow create, delete: if false; // Cloud Functions only
    }

    // ── Metadata (counts, config) ──────────────────────────────────────────────
    // Staff can read aggregated counts. Writes are Cloud Functions only.
    // featuredAnimals is readable publicly — the home page reads it anonymously.

    match /metadata/featuredAnimals {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    match /metadata/{doc} {
      allow read: if isStaff();
      allow write: if false; // Cloud Functions only
    }

    // ── Animal similarity cache ────────────────────────────────────────────────
    // Pre-computed by Cloud Function on animal write. Public read, no client writes.

    match /animalSimilarityCache/{animalId} {
      allow read: if true;
      allow write: if false; // Cloud Functions only
    }

    // ── Rate limits ────────────────────────────────────────────────────────────
    // Internal use only — no client access.

    match /rateLimits/{doc} {
      allow read, write: if false; // Cloud Functions only
    }

    // ── Rejection flags ────────────────────────────────────────────────────────
    // Contém apenas hashes HMAC de CPF/email (nunca PII em texto plano).
    // Leitura: staff pode listar e ler para exibição no painel.
    // Escrita: Cloud Functions only — criação pelo cron, deleção pelo CF deleteRejectionFlag.

    match /rejectionFlags/{flagId} {
      allow read: if isStaff();
      allow write: if false; // Cloud Functions only
    }
  }
}
